# ─────────────────────────────────────────────────────────────────────────────
# Harhurum POS — Environment Variables
# Copy this file to .env and fill in values before running the project.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (MySQL)
DB_NAME=harhurum_pos
DB_USER=harhurum
DB_PASSWORD=securepassword
DB_HOST=localhost
DB_PORT=3306

# Redis (Celery broker + Django Channels)
REDIS_URL=redis://localhost:6379/0

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@harhurum.com.pg
EMAIL_HOST_PASSWORD=emailpassword
DEFAULT_FROM_EMAIL=Harhurum POS <noreply@harhurum.com.pg>

# Staff / manager notification email
MANAGER_EMAIL=manager@harhurum.com.pg

# IRC Tax Compliance
HARHURUM_TIN=
HARHURUM_GST_REG=
TAX_ALERT_EMAIL=accountant@harhurum.com.pg

# File storage
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles

# Security (production)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
